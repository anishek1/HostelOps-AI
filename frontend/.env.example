# ============================================================
# HostelOps AI — Frontend Environment Variables
# Copy this file to .env (for dev) or set as build-time env vars
# in your deployment platform (Railway, Vercel, Netlify, etc.)
#
# IMPORTANT: Vite bakes these values into the JS bundle at build time.
# You MUST set VITE_API_URL before running `npm run build` for production.
# ============================================================

# URL of the deployed backend (no trailing slash, no /api suffix)
# Dev default (if unset): http://localhost:8000
VITE_API_URL=https://your-backend.railway.app
