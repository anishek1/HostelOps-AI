# ============================================================
# HostelOps AI — Environment Variables Template
# Copy this file to .env and fill in all values before running.
# Never commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# --- Auth ---
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- LLM ---
GROQ_API_KEY=
GROQ_MODEL_NAME=llama3-8b-8192

# --- Task Queue ---
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Windows only — use this flag when starting Celery locally:
# .venv\Scripts\celery -A celery_app worker --pool=solo --loglevel=info

# --- Push Notifications (generate with: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=

# --- Agent Thresholds (tune over time) ---
COMPLAINT_CONFIDENCE_THRESHOLD=0.85
MESS_DISSATISFACTION_THRESHOLD=2.5
MESS_SPIKE_DELTA=1.5
LAUNDRY_NOSHOW_PENALTY_HOURS=48
LAUNDRY_UNAVAILABILITY_DAYS=4
APPROVAL_QUEUE_TIMEOUT_MINUTES=30

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
