# ============================================================
# HostelOps AI — Environment Variables Template
# Copy this file to .env and fill in all values before running.
# Never commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# --- Auth ---
JWT_SECRET=                          # generate: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- LLM ---
GROQ_API_KEY=                        # https://console.groq.com
GROQ_MODEL_NAME=llama-3.3-70b-versatile  # DO NOT change — llama3-8b-8192 was decommissioned March 2026

# --- Task Queue (Upstash Redis — free tier works) ---
CELERY_BROKER_URL=rediss://:password@host:6380/0
CELERY_RESULT_BACKEND=rediss://:password@host:6380/0
# Windows dev only — start Celery with: .venv\Scripts\celery -A celery_app worker --pool=solo --loglevel=info

# --- CORS (comma-separated; MUST include your production frontend URL) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example: ALLOWED_ORIGINS=https://hostelops.yourdomain.com

# --- Embeddings / Semantic Deduplication (optional — leave blank to disable) ---
HF_API_KEY=                          # HuggingFace Inference API key (free tier): https://huggingface.co/settings/tokens
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
SIMILARITY_THRESHOLD=0.82            # cosine similarity above this = probable duplicate complaint

# --- Agent Thresholds (tune per hostel; these are the fallback defaults) ---
COMPLAINT_CONFIDENCE_THRESHOLD=0.85
MESS_DISSATISFACTION_THRESHOLD=2.5
MESS_SPIKE_DELTA=1.5
LAUNDRY_NOSHOW_PENALTY_HOURS=48
LAUNDRY_UNAVAILABILITY_DAYS=4
APPROVAL_QUEUE_TIMEOUT_MINUTES=30

# --- Hostel Identity (fallback if DB hostel_config row is missing) ---
HOSTEL_NAME=HostelOps AI
HOSTEL_MODE=college                  # college | autonomous
TOTAL_FLOORS=3
TOTAL_STUDENTS_CAPACITY=200
COMPLAINT_RATE_LIMIT_DAILY=5
LAUNDRY_CANCELLATION_DEADLINE_MINUTES=15

# --- Mess Alert Thresholds ---
MESS_ALERT_THRESHOLD=2.5
MESS_CRITICAL_THRESHOLD=2.0
MESS_MIN_PARTICIPATION=0.15
MESS_MIN_RESPONSES=5

# --- Laundry Slot Generation ---
LAUNDRY_SLOTS_START_HOUR=8
LAUNDRY_SLOTS_END_HOUR=22
LAUNDRY_SLOT_DURATION_HOURS=1
